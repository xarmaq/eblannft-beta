# //
# // Self-bootstrapping loader-wrapper with auto-update.
# //   * On first enable: downloads eblannft_runtime/ into Downloads/eblannft/
# //   * On every enable + on a 4-hour throttle: polls GitHub manifest and, if
# //     a newer version is published, shows an MD3 BottomSheet with change
# //     notes, a real per-byte progress bar, and a Restart button.

from base_plugin import BasePlugin
import importlib
import importlib.util
import json
import os
import re
import sys
import threading
import time

__id__ = "eblannft"
__name__ = "eblanNFT"
