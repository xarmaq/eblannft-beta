def _exec_module_from_source(module_name, source_code, file_name):
    module = types.ModuleType(module_name)
    module.__file__ = file_name
    module.__package__ = module_name.rpartition('.')[0]
    module.__dict__['__builtins__'] = __builtins__
    sys.modules[module_name] = module
    exec(compile(source_code, file_name, 'exec'), module.__dict__)
    return module


def _load_eblannft_impl():
    current_file = os.path.abspath(__file__)
    current_dir = os.path.abspath(os.path.dirname(current_file))
    package_name = '_eblannft_runtime_pkg'

    try:
        pkg_dir = os.path.join(current_dir, 'eblannft_runtime')
        init_py = os.path.join(pkg_dir, '__init__.py')
        plugin_py = os.path.join(pkg_dir, 'plugin.py')
        if os.path.isfile(plugin_py):
            stale_runtime_modules = [
                name for name in tuple(sys.modules.keys())
                if name == package_name or name.startswith(package_name + '.')
            ]
            for module_name in stale_runtime_modules:
                sys.modules.pop(module_name, None)

            if package_name not in sys.modules:
                if os.path.isfile(init_py):
                    pkg_spec = importlib.util.spec_from_file_location(
                        package_name,
                        init_py,
                        submodule_search_locations=[pkg_dir],
                    )
                    if pkg_spec is not None and pkg_spec.loader is not None:
                        pkg_mod = importlib.util.module_from_spec(pkg_spec)
                        sys.modules[package_name] = pkg_mod
                        pkg_spec.loader.exec_module(pkg_mod)
                else:
                    pkg_mod = types.ModuleType(package_name)
                    pkg_mod.__file__ = init_py
                    pkg_mod.__path__ = [pkg_dir]
                    sys.modules[package_name] = pkg_mod

            plugin_name = f'{package_name}.plugin'
            plugin_mod = sys.modules.get(plugin_name)
            if plugin_mod is None:
                plugin_spec = importlib.util.spec_from_file_location(plugin_name, plugin_py)
                if plugin_spec is not None and plugin_spec.loader is not None:
                    plugin_mod = importlib.util.module_from_spec(plugin_spec)
                    sys.modules[plugin_name] = plugin_mod
                    plugin_spec.loader.exec_module(plugin_mod)
            if plugin_mod is not None:
                impl = getattr(plugin_mod, 'NftClonerPlugin', None)
                if isinstance(impl, type):
                    return impl
    except Exception:
        pass

    source = zlib.decompress(base64.b64decode(_EMBEDDED_RUNTIME_B64)).decode('utf-8')
    plugin_mod = _exec_module_from_source(f'{package_name}.embedded_plugin', source, current_file + '#embedded_runtime')
    impl = getattr(plugin_mod, 'NftClonerPlugin', None)
    if isinstance(impl, type):
        return impl
    raise ModuleNotFoundError('No embedded eblannft runtime implementation found')


_LOAD_ERROR = None
try:
    _EblanImpl = _load_eblannft_impl()
except Exception as e:
    _EblanImpl = BasePlugin
    _LOAD_ERROR = e


if isinstance(_EblanImpl, type) and issubclass(_EblanImpl, BasePlugin):
    class EblanNftPlugin(_EblanImpl):
        def on_plugin_load(self):
            if _LOAD_ERROR is not None:
                raise RuntimeError(f'eblanNFT runtime unavailable: {_LOAD_ERROR}')
            parent = getattr(super(), 'on_plugin_load', None)
            if callable(parent):
                return parent()
else:
    class EblanNftPlugin(_EblanImpl, BasePlugin):
        def on_plugin_load(self):
            if _LOAD_ERROR is not None:
                raise RuntimeError(f'eblanNFT runtime unavailable: {_LOAD_ERROR}')
            parent = getattr(super(), 'on_plugin_load', None)
            if callable(parent):
                return parent()


eblanNFTPlugin = EblanNftPlugin
NftClonerPlugin = EblanNftPlugin
